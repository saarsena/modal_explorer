# Copy this file to .env and fill in your values.

# Full path to the Ableton Extensions host module — provided by the Extensions SDK beta
EXTENSION_HOST_PATH=/path/to/ExtensionHostNodeModule.node

# Optional: override the Python engine directory (defaults to engine/ inside the repo)
# COMPOSITION_AIDE_PATH=/custom/path/to/chordgen-parent

# Optional: override the Python command if 'python' is not in your PATH
# PYTHON_CMD=python3
